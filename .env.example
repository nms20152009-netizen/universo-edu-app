# Database Configuration
# Para desarrollo local: file:./db/custom.db
# Para producción en Vercel con Turso:
# DATABASE_URL=libsql://tu-database.turso.io
DATABASE_URL=file:./db/custom.db

# Turso (solo para producción en Vercel)
TURSO_DATABASE_URL=libsql://tu-database-name.turso.io
TURSO_AUTH_TOKEN=tu_token_aqui

# Node Environment
NODE_ENV=production
# OpenRouter API Configuration
OPENROUTER_API_KEY=tu_api_key_aqui

